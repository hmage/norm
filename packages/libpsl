#!/bin/bash

depends_on libidn2

fetch_source https://github.com/rockdaboot/libpsl/releases/download/0.23.0/libpsl-0.23.0.tar.gz 5356a13bc04e031b9788f9edc8b136405f866257

## libpsl 0.22.0 makes a working iconv mandatory for the libidn2 runtime path.
## Apple's system libiconv fails gettext's strict "working iconv" runtime test,
## but it's fine for the UTF-8/ASCII conversions libpsl needs (libidn2 does the
## actual IDNA punycode work). Tell configure to trust it on macOS.
[[ $OSTYPE == *darwin* ]] && export am_cv_func_iconv_works=yes

CONFFLAGS=(
--enable-runtime=libidn2 ## 0.22.0 auto-detection now prefers Apple's libicucore on macOS; pin to libidn2 to keep prior behaviour and actually use our declared dependency
)

do_unpack_compile "${CONFFLAGS[@]}"
