#!/bin/bash

depends_on pkg-config
depends_on flac    ## links with libFLAC
depends_on lame    ## links with libmp3lame
depends_on file    ## links with libmagic, unclear what for
depends_on libogg
depends_on libvorbis
depends_on libpng  ## unclear what for
depends_on libopusfile

fetch_source https://codeberg.org/sox_ng/sox_ng/releases/download/sox_ng-14.8.0.1/sox_ng-14.8.0.1.tar.gz e838ab8a8509f53544e03f2f094b84b0b7fd6cac

CONFFLAGS=(
--enable-replace ## install sox/play/rec/soxi compatibility names
--without-libltdl ## opportunistic linking
--without-amrwb   ## opportunistic linking
--without-amrnb   ## opportunistic linking
--without-mad     ## opportunistic linking
--without-sndfile ## opportunistic linking
--without-fftw    ## opportunistic linking
--without-speexdsp ## opportunistic linking
--without-ladspa  ## opportunistic linking
--without-ffmpeg  ## opportunistic linking
--without-id3tag  ## opportunistic linking
--without-twolame ## opportunistic linking
--without-dolbyb  ## opportunistic linking
--without-ebur128 ## opportunistic linking
--without-wavpack ## opportunistic linking
)

## sox_ng's opus probe needs the nested opus include directory.
## sox does not like -ffast-math
CPPFLAGS="$CPPFLAGS -I$PREFIX/include/opus" \
CFLAGS="${CFLAGS/-Ofast/} -Wno-incompatible-function-pointer-types" \
CXXFLAGS="${CXXFLAGS/-Ofast/} -Wno-incompatible-function-pointer-types" \
do_unpack_compile "${CONFFLAGS[@]}"
