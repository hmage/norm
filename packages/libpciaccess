#!/bin/bash

[[ $OSTYPE != *linux* ]] && log "libpciaccess is a linux-specific library, refusing to build" && false

depends_on meson ninja

fetch_source https://www.x.org/releases/individual/lib/libpciaccess-0.19.tar.xz 4f83983d96d113ffebbc493715ee71a79ee24136

do_unpack
pushd_src
meson setup --prefix="$PREFIX" --buildtype=release builddir
ninja -C builddir
ninja -C builddir install
popd_src
