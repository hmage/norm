#!/bin/bash

fetch_source https://github.com/ip7z/7zip/releases/download/26.02/7z2602-src.tar.xz b47139671f5fefd7b8d5f7a233a0f7953c03fdd0

do_unpack "$TARNAME" --strip-components 0

pushd_src
pushd CPP/7zip/Bundles/Alone2
do_make -f makefile.gcc \
    CFLAGS_BASE2="$CFLAGS $CPPFLAGS" \
    CXXFLAGS_BASE2="$CXXFLAGS $CPPFLAGS" \
    LDFLAGS_STATIC_3="$LDFLAGS"
install -d "$PREFIX/bin" "$PREFIX/share/doc/p7zip"
install -m 755 _o/7zz "$PREFIX/bin/7zz"
ln -sf 7zz "$PREFIX/bin/7z"
ln -sf 7zz "$PREFIX/bin/7za"
ln -sf 7zz "$PREFIX/bin/7zr"
cp -R "$SRCDIR/DOC/." "$PREFIX/share/doc/p7zip/"
popd
popd_src
