#!/bin/bash

depends_on pkg-config
depends_on autoconf automake libtool

[[ $OURNAME == libmount && $OSTYPE != *linux* ]] && log "libmount is a linux-specific library, refusing to build" && false

CONFFLAGS=(
--disable-makeinstall-chown ## otherwise it tries to chown root:root which we don't have permissions for
--with-bashcompletiondir="$PREFIX/etc/bash_completion.d" ## otherwise tries to overwrite system bash-completion if it's installed
--without-ncurses  ## opportunistic linking, though the only tool that has UI is cfdisk
--without-ncursesw ## opportunistic linking, though the only tool that has UI is cfdisk
--disable-cramfs ## cramfs is not widely used, but it has zlib dependency
--without-python ## opportunistic linking, system python might exist but without headers
--disable-liblastlog2 ## needs sqlite3, not main functionality

## these binaries are useless for non-root users
--disable-login
--disable-chfn-chsh
--disable-su
--disable-runuser
)
OURNAME=`basename "${BASH_SOURCE[0]}"` ## get our filename, it could be a library name


[[ $OURNAME == lib* ]] && CONFFLAGS+=(--disable-all-programs --enable-$OURNAME) ## if it's a library, disable building any binaries, and then enable building only specific library
[[ $OURNAME == libmount ]] && CONFFLAGS+=(--enable-libblkid) ## otherwise building libmount fails
[[ $OURNAME == libmount ]] && CONFFLAGS+=(--enable-libuuid)  ## otherwise building glib fails
[[ $OSTYPE == *darwin* ]] && CONFFLAGS+=(--disable-ipcrm --disable-ipcs) ## does not build on darwin
[[ $OSTYPE == *darwin* ]] && CONFFLAGS+=(--disable-libuuid) ## breaks builds of other software on darwin, like ffmpeg

fetch_source https://www.kernel.org/pub/linux/utils/util-linux/v2.42/util-linux-2.42.tar.xz 85b2ba0b56e7cf8a771846e1091a49a8bea1b9af

do_unpack
do_patch_inline -p0 <<'EOF'
--- lib/Makemodule.am
+++ lib/Makemodule.am
@@ -33,7 +33,6 @@
 	lib/mbsedit.c\
 	lib/md5.c \
 	lib/pidutils.c \
-	lib/pidfd-utils.c \
 	lib/pwdutils.c \
 	lib/randutils.c \
 	lib/sha1.c \
@@ -44,7 +43,8 @@
 
 if LINUX
 libcommon_la_SOURCES += \
-	lib/linux_version.c \
-	lib/loopdev.c
+	lib/linux_version.c \
+	lib/loopdev.c \
+	lib/pidfd-utils.c
 endif
 
 if !HAVE_LANGINFO_H
--- Makefile.in
+++ Makefile.in
@@ -178,7 +178,8 @@
 test_open_twice$(EXEEXT)
 @LINUX_TRUE@am__append_4 = \
 @LINUX_TRUE@	lib/linux_version.c \
-@LINUX_TRUE@	lib/loopdev.c
+@LINUX_TRUE@	lib/loopdev.c \
+@LINUX_TRUE@	lib/pidfd-utils.c
 
 @HAVE_LANGINFO_H_FALSE@am__append_5 = lib/langinfo.c
 @HAVE_CPU_SET_T_TRUE@am__append_6 = lib/cpuset.c
@@ -1706,14 +1707,15 @@
 	lib/crc64.c lib/c_strtod.c lib/debug.c lib/encode.c lib/env.c \
 	lib/fileutils.c lib/idcache.c lib/jsonwrt.c lib/mangle.c \
 	lib/match.c lib/mbsalign.c lib/mbsedit.c lib/md5.c \
-	lib/pidutils.c lib/pidfd-utils.c lib/pwdutils.c \
+	lib/pidutils.c lib/pwdutils.c \
 	lib/randutils.c lib/sha1.c lib/sha256.c lib/shells.c \
 	lib/signames.c lib/strutils.c lib/strv.c lib/timeutils.c \
 	lib/ttyutils.c lib/xxhash.c lib/configs.c lib/linux_version.c \
 	lib/loopdev.c lib/langinfo.c lib/cpuset.c lib/path.c \
 	lib/sysfs.c lib/procfs.c
 @LINUX_TRUE@am__objects_2 = lib/libcommon_la-linux_version.lo \
-@LINUX_TRUE@	lib/libcommon_la-loopdev.lo
+@LINUX_TRUE@	lib/libcommon_la-loopdev.lo \
+@LINUX_TRUE@	lib/libcommon_la-pidfd-utils.lo
 @HAVE_LANGINFO_H_FALSE@am__objects_3 = lib/libcommon_la-langinfo.lo
 @HAVE_CPU_SET_T_TRUE@am__objects_4 = lib/libcommon_la-cpuset.lo
 @HAVE_DIRFD_TRUE@@HAVE_OPENAT_TRUE@am__objects_5 =  \
@@ -1730,7 +1732,7 @@
 	lib/libcommon_la-jsonwrt.lo lib/libcommon_la-mangle.lo \
 	lib/libcommon_la-match.lo lib/libcommon_la-mbsalign.lo \
 	lib/libcommon_la-mbsedit.lo lib/libcommon_la-md5.lo \
-	lib/libcommon_la-pidutils.lo lib/libcommon_la-pidfd-utils.lo \
+	lib/libcommon_la-pidutils.lo \
 	lib/libcommon_la-pwdutils.lo lib/libcommon_la-randutils.lo \
 	lib/libcommon_la-sha1.lo lib/libcommon_la-sha256.lo \
 	lib/libcommon_la-shells.lo lib/libcommon_la-signames.lo \
@@ -6235,7 +6237,7 @@
 	lib/c_strtod.c lib/debug.c lib/encode.c lib/env.c \
 	lib/fileutils.c lib/idcache.c lib/jsonwrt.c lib/mangle.c \
 	lib/match.c lib/mbsalign.c lib/mbsedit.c lib/md5.c \
-	lib/pidutils.c lib/pidfd-utils.c lib/pwdutils.c \
+	lib/pidutils.c lib/pwdutils.c \
 	lib/randutils.c lib/sha1.c lib/sha256.c lib/shells.c \
 	lib/signames.c lib/strutils.c lib/strv.c lib/timeutils.c \
 	lib/ttyutils.c lib/xxhash.c lib/configs.c $(am__append_4) \
EOF
do_compile "${CONFFLAGS[@]}"
