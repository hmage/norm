#!/bin/bash

[[ $OSTYPE != *linux* ]] && log "libdrm is a linux-specific library, refusing to build" && false

depends_on pkg-config
depends_on libpciaccess
depends_on meson ninja

fetch_source https://dri.freedesktop.org/libdrm/libdrm-2.4.134.tar.xz 5c6452dfcceea5ed1073c2de4d826c4c5f59838d

do_unpack
pushd_src
meson setup --prefix="$PREFIX" --buildtype=release builddir
ninja -C builddir
ninja -C builddir install
popd_src
