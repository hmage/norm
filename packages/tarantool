#!/bin/bash

needs_tool cmake
[[ $OSTYPE != *darwin* ]] && depends_on libncurses ## opportunistic linking with libtinfo
depends_on libicu
depends_on autoconf automake libtool ## needed for bundled libraries
depends_on zlib ## opportunistic linking

needs_tool git ## build system needs git for some reason

fetch_source https://download.tarantool.org/tarantool/src/tarantool-3.7.0.tar.gz e5f2c205e726ebb28415a273824652b3e5ec478a

do_unpack_compile -DREADLINE_ROOT="$PREFIX" -DICU_ROOT="$PREFIX" -DCURSES_INCLUDE_PATH="$PREFIX/include/ncurses" -DENABLE_BUNDLED_OPENSSL=ON -DENABLE_BUNDLED_READLINE=ON -DCMAKE_OSX_SYSROOT="$(xcrun --show-sdk-path)"
