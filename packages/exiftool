#!/bin/bash

fetch_source https://sourceforge.net/projects/exiftool/files/Image-ExifTool-13.59.tar.gz/download 8429367c8289c21499696dcba6fc6b8eb2de5017 Image-ExifTool-13.59.tar.gz

do_unpack
pushd_src
perl Makefile.PL INSTALL_BASE="$PREFIX"
sed -i.bak \
    -e "s|^[[:space:]]*my .*incDir = .*$|    my \$incDir = \"$PREFIX/lib/perl5\";|" \
    -e "s|\$exeDir/lib|$PREFIX/lib/perl5|" \
    exiftool
make install
popd_src
