#!/bin/bash

fetch_source https://sourceforge.net/projects/exiftool/files/Image-ExifTool-13.57.tar.gz/download 1baf6e59e30c8c83c2cf7c2933eaabb339101384 Image-ExifTool-13.57.tar.gz

do_unpack
pushd_src
perl Makefile.PL INSTALL_BASE="$PREFIX"
sed -i.bak \
    -e "s|^[[:space:]]*my .*incDir = .*$|    my \$incDir = \"$PREFIX/lib/perl5\";|" \
    -e "s|\$exeDir/lib|$PREFIX/lib/perl5|" \
    exiftool
make install
popd_src
