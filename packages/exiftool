#!/bin/bash

fetch_source https://sourceforge.net/projects/exiftool/files/Image-ExifTool-13.58.tar.gz/download ba477e9d7a18972fdcf90c61b27b4ed36021e844 Image-ExifTool-13.58.tar.gz

do_unpack
pushd_src
perl Makefile.PL INSTALL_BASE="$PREFIX"
sed -i.bak \
    -e "s|^[[:space:]]*my .*incDir = .*$|    my \$incDir = \"$PREFIX/lib/perl5\";|" \
    -e "s|\$exeDir/lib|$PREFIX/lib/perl5|" \
    exiftool
make install
popd_src
