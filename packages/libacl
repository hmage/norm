#!/bin/bash

[[ $OSTYPE != *linux* ]] && log "libacl is a linux-specific library, refusing to build" && false

depends_on libattr

fetch_source https://download.savannah.nongnu.org/releases/acl/acl-2.4.0.tar.xz 194272659d2cfad5180a4cf7eb9a4b3c28a6afe9

do_unpack

pushd_src
do_configure --enable-gettext=no
do_make
do_test
do_install
popd
