#!/bin/bash

depends_on libgpg-error
depends_on libassuan
depends_on libncurses

fetch_source https://www.gnupg.org/ftp/gcrypt/pinentry/pinentry-1.3.3.tar.bz2 70dabf5032b1f9810521f35ca1770e99d0cf3d0c

CONFOPTS=(
--disable-pinentry-qt
--disable-pinentry-qt4
--disable-pinentry-qt5
--disable-pinentry-gnome3
--enable-pinentry-curses
--disable-pinentry-gtk2
--enable-pinentry-tty
--disable-libsecret
--without-libcap
)

## Apple's iconv fails gettext's pedantic "working iconv" run test (it transliterates
## instead of returning EILSEQ), which makes configure drop -liconv entirely and the
## curses flavour fails to link with undefined _iconv_*. It worked fine for 1.3.2.
[[ $OSTYPE == *darwin* ]] && export am_cv_func_iconv_works=yes

do_unpack_compile "${CONFOPTS[@]}"
