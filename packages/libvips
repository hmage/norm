#!/bin/bash

depends_on glib     ## uses gobject-introspection
[[ $OSTYPE != *darwin* ]] && depends_on libexpat ## what for? also on osx it's always there, don't build our own
depends_on meson
depends_on ninja

## image formats
depends_on libpng
depends_on libjpeg
depends_on libheif
depends_on libtiff
depends_on libwebp
depends_on libexif
depends_on libgif

## opportunistic linking
depends_on liblcms2

fetch_source https://github.com/libvips/libvips/releases/download/v8.18.4/vips-8.18.4.tar.xz a11933e3cbd12fe6bde1464bba7cab1463966e23

do_unpack
BUILDDIR="$SRCDIR"-build
rm -rf "$BUILDDIR"
mkdir -p "$BUILDDIR"
pushd "$BUILDDIR"
meson setup --prefix="$PREFIX" --buildtype=release "$SRCDIR"
ninja -j$NUMJOBS
ninja install
popd
