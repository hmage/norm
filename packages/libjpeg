#!/bin/bash

needs_tool cmake

fetch_source https://github.com/libjpeg-turbo/libjpeg-turbo/releases/download/3.2.0/libjpeg-turbo-3.2.0.tar.gz 1237089621aaed89dab23c2cbb9691fdbeb9fe33

do_unpack
## some programs define JPEG_INTERNALS and fail to compile since by default it's not added by this fork of libjpeg
do_patch_inline << "EOF"
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2065,6 +2065,7 @@
 install(FILES ${CMAKE_CURRENT_BINARY_DIR}/jconfig.h
   ${CMAKE_CURRENT_SOURCE_DIR}/src/jerror.h
   ${CMAKE_CURRENT_SOURCE_DIR}/src/jmorecfg.h
   ${CMAKE_CURRENT_SOURCE_DIR}/src/jpeglib.h
+  ${CMAKE_CURRENT_SOURCE_DIR}/src/jpegint.h
   DESTINATION ${CMAKE_INSTALL_INCLUDEDIR} COMPONENT include)
 
 include(cmakescripts/BuildPackages.cmake)
EOF
do_compile -DWITH_JPEG8=ON
