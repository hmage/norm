#!/bin/bash

needs_tool cmake

depends_on libsdl2 ## runtime and build-time SDL2 compatibility layer dependency

fetch_source https://github.com/libsdl-org/sdl12-compat/releases/download/release-1.2.76/sdl12-compat-1.2.76.tar.gz 67ab7248f14d42c8bf74f27b05b8270b8cf688bd

do_unpack_compile -DSDL12TESTS=OFF

ln -sf sdl12_compat.pc "$PREFIX/lib/pkgconfig/sdl.pc"
