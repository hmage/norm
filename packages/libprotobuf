#!/bin/bash

[[ $OSTYPE != *darwin* ]] && depends_on zlib ## enables GzipInputStream, osx provides the library
depends_on libabsl

fetch_source https://github.com/protocolbuffers/protobuf/releases/download/v35.1/protobuf-35.1.tar.gz e60516cf44abbf03273e360289f020e5854390e4

do_unpack
pushd_src
do_cmake -Dprotobuf_BUILD_TESTS=OFF
find . -name flags.make -exec sed -ibak "s|-I$PREFIX/include ||g" {} +
do_make_and_install
popd_src
