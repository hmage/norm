#!/bin/bash

[[ $OSTYPE != *darwin* ]] && depends_on zlib ## enables GzipInputStream, osx provides the library
depends_on libabsl

fetch_source https://github.com/protocolbuffers/protobuf/releases/download/v34.0/protobuf-34.0.tar.gz de5bb9c84f51ff34752fc2dc985031cbe48efc18

do_unpack
pushd_src
do_cmake -Dprotobuf_BUILD_TESTS=OFF
find . -name flags.make -exec sed -ibak "s|-I$PREFIX/include ||g" {} +
do_make_and_install
popd_src
