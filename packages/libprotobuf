#!/bin/bash

[[ $OSTYPE != *darwin* ]] && depends_on zlib ## enables GzipInputStream, osx provides the library
depends_on libabsl

fetch_source https://github.com/protocolbuffers/protobuf/releases/download/v34.1/protobuf-34.1.tar.gz cf330b88f60246ca291d373f5748e26db0184ee8

do_unpack
pushd_src
do_cmake -Dprotobuf_BUILD_TESTS=OFF
find . -name flags.make -exec sed -ibak "s|-I$PREFIX/include ||g" {} +
do_make_and_install
popd_src
