#!/bin/bash

[[ $OSTYPE != *darwin* ]] && depends_on zlib ## enables GzipInputStream, osx provides the library
depends_on libabsl

fetch_source https://github.com/protocolbuffers/protobuf/releases/download/v35.0/protobuf-35.0.tar.gz 5e29544165f0538bbf50b4de9cb97d746faa0cd5

do_unpack
pushd_src
do_cmake -Dprotobuf_BUILD_TESTS=OFF
find . -name flags.make -exec sed -ibak "s|-I$PREFIX/include ||g" {} +
do_make_and_install
popd_src
