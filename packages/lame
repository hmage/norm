#!/bin/bash

needs_tool nasm

depends_on libmpg123 ## 4.0 dropped the internal mpglib decoder, `lame --decode` needs libmpg123

fetch_source https://downloads.sourceforge.net/sourceforge/lame/lame-4.0.tar.gz e3630adf399d8917d4da19b96937b7f9b12774ea

CONFFLAGS=(
--enable-nasm
--enable-shared
)

do_unpack
# 4.0 guards setlocale() with HAVE_LANGINFO_H but only includes <locale.h> with working iconv
perl -i.bak -pe 's|^#include <ctype\.h>$|#include <ctype.h>\n#include <locale.h>|' "$SRCDIR/frontend/parse.c"
do_compile "${CONFFLAGS[@]}"
