#!/bin/bash

needs_tool python3

fetch_source https://github.com/mesonbuild/meson/releases/download/1.11.2/meson-1.11.2.tar.gz 43ba6823e209bed087e00620d367ce30708a9a13

do_unpack
pushd_src
# Install into a venv so the entrypoint shebang finds the meson
# package without requiring a full CPython build from source.
MESON_VENV="$PREFIX/lib/meson-venv"
python3 -m venv --clear --system-site-packages "$MESON_VENV"
mkdir -p "$PREFIX/var/norm"
"$MESON_VENV/bin/python3" setup.py install --single-version-externally-managed --record="$PREFIX/var/norm/meson.install-record"
popd_src
ln -sf "$MESON_VENV/bin/meson" "$PREFIX/bin/meson"
